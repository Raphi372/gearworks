// ============================================================================
// Gearworks — Prisma schema (PostgreSQL)
// Used only when STORAGE=postgres. The default file backend needs none of this.
// Generate client:  npm run db:generate
// Apply migrations:  npm run db:migrate         (production)
//                    npm run db:migrate:dev     (local, creates migrations)
// See docs/DATABASE.md.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Accounts: optional player identity for the persistent metagame --------
model Account {
  id           String   @id @default(cuid())
  username     String   @unique              // canonical login identifier
  email        String?  @unique
  emailVerified Boolean @default(false)       // set once the address is confirmed
  displayName  String
  color        String   @default("#4aa3ff")
  tokenVersion Int      @default(0)            // bump to invalidate all sessions (reset / logout-all)
  passwordHash String? // "saltHex:hashHex" (scrypt); null for guest accounts
  isGuest      Boolean  @default(false)
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  worlds       World[]      @relation("OwnedWorlds")
  memberships  WorldMember[]
  progression  Progression?
  profile      Profile?
  ban          Ban?
  stats        Stat[]
  friendsFrom  Friendship[] @relation("FriendFrom")
  friendsTo    Friendship[] @relation("FriendTo")
  reportsMade    Report[]   @relation("ReportsMade")
  reportsAgainst Report[]   @relation("ReportsAgainst")
  flag         Flag?

  @@index([lastSeenAt])
}

// ---- Flag: an anti-cheat anomaly flag on an account, 1:1 (Phase 3) ----------
// A human-in-the-loop signal (score, don't auto-ban): the anomaly scorer records
// one when a player's weighted anomaly score crosses the threshold. `count` is
// how many times they've been flagged; latest reason/score/room win.
model Flag {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reason    String   @default("")
  score     Int      @default(0)
  roomCode  String?
  count     Int      @default(1)
  updatedAt DateTime @updatedAt
}

// ---- Report: a player flags another account for admin review (Phase 3) ------
// One open report per (reporter, target); an admin resolves or dismisses it,
// optionally issuing a Ban. Enforcement/visibility is admin-gated server-side.
model Report {
  id         String       @id @default(cuid())
  reporterId String
  reporter   Account      @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId   String
  target     Account      @relation("ReportsAgainst", fields: [targetId], references: [id], onDelete: Cascade)
  reason     String       @default("")
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())

  @@unique([reporterId, targetId])
  @@index([status])
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

// ---- Ban: a moderation hold on an account, 1:1 with Account ----------------
// `until` null = permanent; a lapsed ban is treated as inactive. Enforced at
// login and session resume (server-side); admins are set via ADMIN_USERS.
model Ban {
  id        String    @id @default(cuid())
  accountId String    @unique
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reason    String    @default("")
  by        String    @default("")          // admin username who issued it
  until     DateTime?                        // null = permanent
  createdAt DateTime  @default(now())
}

// ---- Profile: vanity layer (bio + equipped cosmetics), 1:1 with Account -----
// Only the equipped loadout + bio are stored; cosmetic OWNERSHIP is a derived
// projection of progression (shared/cosmetics.js), never persisted.
model Profile {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  bio       String   @default("")
  equipped  Json     @default("{}")          // { nameplate?: key, title?: key }
  updatedAt DateTime @updatedAt
}

// ---- Social graph: directed friend/request/block edges ---------------------
// A PENDING row (accountId → otherId) is a request; an ACCEPTED friendship is
// stored as a row in BOTH directions; a BLOCKED row is one-directional.
model Friendship {
  id        String       @id @default(cuid())
  accountId String
  account   Account      @relation("FriendFrom", fields: [accountId], references: [id], onDelete: Cascade)
  otherId   String
  other     Account      @relation("FriendTo", fields: [otherId], references: [id], onDelete: Cascade)
  status    FriendStatus @default(PENDING)
  createdAt DateTime     @default(now())

  @@unique([accountId, otherId])
  @@index([otherId, status])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// ---- Worlds: an authoritative saved game (one room) ------------------------
// `snapshot` is the shared/core.js Snapshot.capture() blob — the same format
// the file backend stores. Stored as JSONB so it is queryable if needed.
model World {
  id         String   @id @default(cuid())
  code       String   @unique          // 6-char invite code
  name       String
  seed       BigInt?
  snapshot   Json?                       // deterministic sim snapshot (null when externalized)
  snapshotRef String?                    // blob key when the snapshot lives in object/fs storage
  isPublic   Boolean  @default(true)
  savedAt    DateTime @default(now())
  createdAt  DateTime @default(now())

  ownerId    String?
  owner      Account? @relation("OwnedWorlds", fields: [ownerId], references: [id], onDelete: SetNull)

  members    WorldMember[]
  factories  Factory[]

  @@index([isPublic, savedAt])
  @@index([ownerId])
}

// ---- Membership + role in a world (host/admin/player/spectator) ------------
model WorldMember {
  id        String   @id @default(cuid())
  role      Role     @default(PLAYER)
  joinedAt  DateTime @default(now())

  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  worldId   String
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@unique([accountId, worldId])
  @@index([worldId])
}

enum Role {
  HOST
  ADMIN
  PLAYER
  SPECTATOR
}

// ---- Factories: denormalized per-world production summary ------------------
// The authoritative truth is inside World.snapshot; this table is an indexed
// projection for leaderboards / analytics without deserializing snapshots.
model Factory {
  id          String   @id @default(cuid())
  worldId     String   @unique            // one projection row per world (upserted on save)
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  entityCount Int      @default(0)
  money       Int      @default(0)
  techTier    Int      @default(0)         // count of researched techs
  techIds     String[] @default([])        // researched tech ids (for the progression union)
  updatedAt   DateTime @updatedAt

  @@index([money])                        // leaderboard ordering
}

// ---- Progression: cross-world account progression --------------------------
model Progression {
  id            String   @id @default(cuid())
  accountId     String   @unique
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  level         Int      @default(1)
  xp            Int      @default(0)
  unlockedTech  String[] @default([])
  updatedAt     DateTime @updatedAt
}

// ---- Stats: time-series counters (production, playtime, …) -----------------
model Stat {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  key        String                       // e.g. "iron_plate_produced", "playtime_sec"
  value      BigInt   @default(0)
  recordedAt DateTime @default(now())

  @@index([accountId, key])
}
