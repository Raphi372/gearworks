# Gearworks server configuration.
#   • Copy to .env — the server auto-loads it (server/config.js), no dependency.
#   • All are optional; sensible defaults apply.
#   • Real environment variables (Docker/CI/PM2) always override .env.
#   • Put each value on its own line; no inline "# comments" after a value.
# See docs/PRODUCTION.md, and docs/FREE_DEPLOYMENT_GUIDE.md for the $0 self-host.

# --- core ---
PORT=8080
# HOST 0.0.0.0 exposes the port to your whole LAN. When self-hosting behind a
# Cloudflare Tunnel, bind to loopback so ONLY the tunnel can reach the server:
#   HOST=127.0.0.1
HOST=0.0.0.0
NODE_ENV=development

# --- persistence ---
# STORAGE=file (default, zero-dependency) or STORAGE=postgres
STORAGE=file
SAVE_DIR=saves
# Required only when STORAGE=postgres. Neon's free tier gives you this string
# under "Connection Details" (use the pooled URL). Keep sslmode=require:
# STORAGE=postgres
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/gearworks?sslmode=require
# DATABASE_REPLICA_URL=  # optional read replica: leaderboard/my-worlds/stats reads route here; writes + authz stay on the primary

# --- restart continuity ---
# On boot, re-create worlds saved within RESTORE_WINDOW_MIN as live rooms so a
# restart/deploy/crash doesn't end ongoing games. Set RESTORE_ON_BOOT=0 to skip.
# RESTORE_ON_BOOT=1
# RESTORE_WINDOW_MIN=30

# --- limits (optional overrides) ---
# MAX_ROOMS=32
# MAX_PLAYERS_PER_ROOM=16
# CMD_RATE_LIMIT=100
# EMPTY_ROOM_TTL_MS=600000

# --- accounts / auth ---
# AUTH_SECRET signs session tokens. MUST be a stable random string in
# production (sessions break on restart otherwise). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_SECRET=
# TOKEN_TTL_DAYS=30
# RECONNECT_TTL_MIN=60      # how long a reconnect token can rejoin a live game
# LOGIN_MAX_ATTEMPTS=8

# --- account recovery (password reset / email verification) ---
# Zero-dependency mailer. Without a provider the server still runs; recovery
# email just isn't delivered. Use Resend (free tier, HTTP API — no SMTP):
#   1. create an API key at resend.com, 2. set the three vars below.
# MAIL_PROVIDER=resend
# MAIL_API_KEY=re_xxxxxxxx
# MAIL_FROM=Gearworks <noreply@yourdomain.com>
# APP_URL=https://gearworks.pages.dev   # used to build clickable reset links
# RESET_TTL_MIN=45                        # reset/verify code lifetime (minutes)

# --- operations ---
# MAINTENANCE=1            # reject new games with a notice (client shows a banner)
# ADMIN_USERS=            # comma-separated usernames granted the ban tools (moderation panel). Empty = no admins.
# ANTICHEAT_FLAG_SCORE=60 # anomaly score that records an admin flag (0 disables); decay + cooldown below
# ANTICHEAT_DECAY_MS=15000
# ANTICHEAT_COOLDOWN_MS=60000
# ERROR_WEBHOOK=           # optional: POST uncaught errors as JSON (Sentry URL or your own)

# --- CORS for /health (monitoring dashboards) ---
# ALLOW_ORIGIN=*

# --- multi-instance / regions (single-instance $0 deploy needs none of this) ---
# REGION=local            # this instance's region label; surfaced in the client's region picker when 2+ regions exist
# DIRECTORY=local         # 'local' (single instance) | 'file' (shared room router across instances)
# DIRECTORY_DIR=          # shared directory path when DIRECTORY=file (defaults to <SAVE_DIR>/directory)
# PUBLIC_URL=             # this instance's reachable ws(s):// URL, used for cross-instance join handoff
# SNAPSHOT_STORE=inline   # where room blobs live: inline (default) | fs (shared dir) | s3 (object storage)
# PRESENCE=local          # friend presence: local (default) | file (shared dir) | redis (shared cache)
# INVITES=local           # world invites: local (default) | file (shared dir) | redis (shared cache)
# REDIS_URL=              # e.g. redis://:pass@host:6379 — required when PRESENCE=redis or INVITES=redis
# PRESENCE_REFRESH_MS=5000 # redis backend: how often each instance refreshes the cluster presence cache
# INVITE_REFRESH_MS=5000   # redis backend: how often each instance refreshes the cluster invite cache
# --- object-storage snapshots (SNAPSHOT_STORE=s3; requires STORAGE=postgres) ---
# SNAPSHOT_S3_ENDPOINT=   # e.g. https://<acct>.r2.cloudflarestorage.com  or  https://s3.<region>.amazonaws.com
# SNAPSHOT_S3_BUCKET=
# SNAPSHOT_S3_REGION=auto # 'auto' for Cloudflare R2; the bucket's region for AWS S3
# SNAPSHOT_S3_ACCESS_KEY=
# SNAPSHOT_S3_SECRET_KEY=
# SNAPSHOT_S3_PREFIX=     # optional key prefix, e.g. snapshots/
