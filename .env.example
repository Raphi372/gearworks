# Gearworks server configuration — copy to .env for local dev.
# All are optional; sensible defaults apply. See docs/PRODUCTION.md.

# --- core ---
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# --- persistence ---
# STORAGE=file (default, zero-dependency) or STORAGE=postgres
STORAGE=file
SAVE_DIR=saves
# Required only when STORAGE=postgres:
# DATABASE_URL=postgresql://user:password@host:5432/gearworks?sslmode=require

# --- limits (optional overrides) ---
# MAX_ROOMS=32
# MAX_PLAYERS_PER_ROOM=16
# CMD_RATE_LIMIT=100
# EMPTY_ROOM_TTL_MS=600000

# --- accounts / auth ---
# AUTH_SECRET signs session tokens. MUST be a stable random string in
# production (sessions break on restart otherwise). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_SECRET=
# TOKEN_TTL_DAYS=30
# LOGIN_MAX_ATTEMPTS=8

# --- operations ---
# MAINTENANCE=1            # reject new games with a notice (client shows a banner)
# ERROR_WEBHOOK=           # optional: POST uncaught errors as JSON (Sentry URL or your own)

# --- CORS for /health (monitoring dashboards) ---
# ALLOW_ORIGIN=*
